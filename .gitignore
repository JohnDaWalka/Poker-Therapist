# Python cache
__pycache__/
*.py[cod]
*.pyo

# SQLite databases (generated at runtime)
*.db
*.sqlite3

# PQC Security - NEVER commit private keys!
*.key
!*.pub.json
security/config.yaml
!security/config.template.yaml
!security/*.pqc

